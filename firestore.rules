rules_version = '2';

// Security model for the 1ATF portal.
//  - Public operational content (content/*) is world-readable but only RHQ can write.
//  - Roster + tasks are readable by signed-in users; only RHQ can write.
//  - A user may read/write only their own users/{uid} profile.
//
// "RHQ" is determined by the role field on the caller's own user profile.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isRHQ() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'RHQ';
    }

    // Public site content — anyone can read, RHQ edits.
    match /content/{doc} {
      allow read: if true;
      allow write: if isRHQ();
    }

    // Pre-provisioned roster (used to link new accounts).
    match /roster/{id} {
      allow read: if isSignedIn();
      allow write: if isRHQ();
    }

    // Distributed digital activities + activity feed.
    match /tasks/{id} {
      allow read: if isSignedIn();
      allow write: if isRHQ();
    }
    match /activity/{id} {
      allow read: if isSignedIn();
      allow write: if isRHQ();
    }

    // Personnel profiles. Users manage their own; RHQ can manage all.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update, delete: if request.auth.uid == uid || isRHQ();
    }

    // Help / support messages — anyone (incl. signed-out) may submit; RHQ reads.
    match /support/{id} {
      allow create: if true;
      allow read, update, delete: if isRHQ();
    }

    // Forgotten-password requests — anyone may raise; RHQ reads and actions.
    match /resetRequests/{id} {
      allow create: if true;
      allow read, update, delete: if isRHQ();
    }

    // Public auth-version index (no sensitive data) so login can compute the
    // current credential epoch before sign-in; RHQ bumps it on a reset.
    match /authIndex/{id} {
      allow read: if true;
      allow write: if isRHQ();
    }
  }
}
