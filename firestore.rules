rules_version = '2';

// Security model for the 1ATF portal.
//
//  - Public operational content (content/*) is world-readable; only RHQ writes.
//  - roster / tasks / activity are readable by any signed-in member (the client
//    needs the roster query during temporary-password registration, before the
//    member has a profile that marks them RHQ); only RHQ writes.
//  - users/{uid}: a member may read and update ONLY their own profile, and may
//    NOT change their own role or ID number (anti-escalation); RHQ manages all.
//  - support / resetRequests: anyone (incl. signed-out) may submit a single,
//    size-bounded request; only RHQ can read or action them.
//  - authIndex/{id}: public read (login computes the credential epoch before
//    sign-in); only RHQ bumps it on a password reset.
//  - Everything else is denied by default.
//
// "RHQ" is determined by the role field on the caller's own user profile.
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------- helpers
    function isSignedIn() {
      return request.auth != null;
    }
    function userDoc() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }
    function isRHQ() {
      return isSignedIn()
        && exists(userDoc())
        && get(userDoc()).data.role == 'RHQ';
    }
    // A Company Commander bound to company `coy`. Commanders may only ever act on
    // their own company's data.
    function isCommanderOf(coy) {
      return isSignedIn()
        && exists(userDoc())
        && get(userDoc()).data.role == 'Company Commander'
        && get(userDoc()).data.company == coy;
    }
    // True when a (possibly missing) field is a string no longer than `max`.
    function strOk(data, key, max) {
      return !(key in data) || (data[key] is string && data[key].size() <= max);
    }

    // ------------------------------------------------------- public site content
    // Anyone can read; RHQ edits.
    match /content/{doc} {
      allow read: if true;
      allow write: if isRHQ();
    }

    // --------------------------------------------------------------- roster
    // Read access is required by every signed-in member because temporary-
    // password registration queries the roster before the member has an RHQ
    // marker. Writes are RHQ-only. (Tightening reads to RHQ-only would require
    // a matching change to the registration flow in the app.)
    match /roster/{id} {
      allow read:  if isSignedIn();
      allow write: if isRHQ();
    }

    // ------------------------------------------ distributed tasks + activity feed
    match /tasks/{id} {
      allow read:  if isSignedIn();
      allow write: if isRHQ();
    }
    match /activity/{id} {
      allow read:  if isSignedIn();
      allow write: if isRHQ();
    }

    // ------------------------------------------------------ personnel profiles
    // A member reads only their own profile; RHQ reads all. On self-update a
    // member may not change their role or ID number — only RHQ can. Profiles are
    // never deleted by their owner.
    match /users/{uid} {
      allow read:   if isRHQ() || (isSignedIn() && request.auth.uid == uid);
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isRHQ()
        || (request.auth.uid == uid
            && request.resource.data.role == resource.data.role
            && request.resource.data.idNumber == resource.data.idNumber);
      allow delete: if isRHQ();
    }

    // ------------------------------------------------------- help / support inbox
    // Anyone (incl. signed-out) may file ONE bounded request; RHQ reads/actions.
    match /support/{id} {
      allow create: if request.resource.data.keys()
                        .hasOnly(['category','name','idNumber','contact','message','code','auto','ts','status'])
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 5000
        && strOk(request.resource.data, 'category', 64)
        && strOk(request.resource.data, 'name', 200)
        && strOk(request.resource.data, 'idNumber', 64)
        && strOk(request.resource.data, 'contact', 200)
        && strOk(request.resource.data, 'code', 32);
      allow read, update, delete: if isRHQ();
    }

    // --------------------------------------------------- forgotten-password inbox
    // Anyone may raise a reset request; RHQ reads and actions it.
    match /resetRequests/{id} {
      allow create: if request.resource.data.keys().hasOnly(['idNumber','ts','status'])
        && request.resource.data.idNumber is string
        && request.resource.data.idNumber.size() > 0
        && request.resource.data.idNumber.size() <= 64;
      allow read, update, delete: if isRHQ();
    }

    // ------------------------------------------------------------- audit log
    // Record of RHQ actions. RHQ only — created, read and cleared by RHQ; never
    // edited in place.
    match /audit/{id} {
      allow read, create, delete: if isRHQ();
      allow update: if false;
    }

    // -------------------------------------------------- public auth-version index
    // No sensitive data — just the credential epoch — so login can read it before
    // sign-in. RHQ bumps it on a reset.
    match /authIndex/{id} {
      allow read:  if true;
      allow write: if isRHQ()
        && request.resource.data.keys().hasOnly(['pwVersion'])
        && request.resource.data.pwVersion is int;
    }

    // ------------------------------------------- intel approval queue (drafts)
    // Company Commanders submit intel changes for THEIR company; the change is
    // not public until RHQ approves it (approval writes content/intel and clears
    // the submission). A commander may only read/write submissions carrying
    // their own company code; RHQ manages the whole queue. Commander list
    // queries must be filtered by company (the app does this) to satisfy read.
    match /intelSubmissions/{id} {
      allow read:   if isRHQ() || isCommanderOf(resource.data.company);
      allow create: if isRHQ() || (isCommanderOf(request.resource.data.company)
                                   && request.resource.data.status == 'pending');
      allow update: if isRHQ() || (isCommanderOf(resource.data.company)
                                   && request.resource.data.company == resource.data.company);
      allow delete: if isRHQ() || isCommanderOf(resource.data.company);
    }

    // ------------------------------------------------------------- default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
